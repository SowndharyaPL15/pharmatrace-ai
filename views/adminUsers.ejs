<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"><meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Users — PharmaTrace AI</title>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css">
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
<%- include('partials/navbar') %>
<div class="container-fluid px-4 py-4">
  <h4 class="fw-bold mb-4">👥 User Management</h4>
  <div class="card">
    <div class="table-responsive">
      <table class="table table-hover mb-0">
        <thead class="table-dark">
          <tr><th>#</th><th>Username</th><th>Email</th><th>Role</th><th>Organization</th><th>Joined</th></tr>
        </thead>
        <tbody>
        <% users.forEach((u, i) => { %>
          <tr>
            <td class="text-muted small"><%= i+1 %></td>
            <td class="fw-semibold"><%= u.username %></td>
            <td class="small"><%= u.email %></td>
            <td><span class="badge bg-primary"><%= u.role.toUpperCase() %></span></td>
            <td class="small text-muted"><%= u.organization || '—' %></td>
            <td class="small text-muted"><%= new Date(u.created_at).toLocaleDateString('en-IN') %></td>
          </tr>
        <% }) %>
        </tbody>
      </table>
    </div>
  </div>
</div>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
