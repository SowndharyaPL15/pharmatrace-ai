<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Dashboard — PharmaTrace AI</title>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css">
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
<%- include('partials/navbar') %>

<div class="container-fluid px-4 py-4">

  <!-- Welcome bar -->
  <div class="d-flex flex-wrap align-items-center justify-content-between mb-4 gap-3">
    <div>
      <h4 class="fw-bold mb-0">Welcome back, <span class="text-primary"><%= user.username %></span> 👋</h4>
      <p class="text-muted mb-0 small">
        <span class="badge bg-primary"><%= user.role.toUpperCase() %></span>
        <% if(user.organization){ %> · <%= user.organization %><% } %>
      </p>
    </div>
    <div class="d-flex gap-2">
      <% if(user.role==='manufacturer'){ %>
        <a href="/medicines/add" class="btn btn-primary btn-sm">➕ Register Batch</a>
      <% } %>
      <% if(user.role==='inspector' || user.role==='admin'){ %>
        <a href="/testing" class="btn btn-success btn-sm">🔬 Run Test</a>
      <% } %>
      <a href="/verify" class="btn btn-outline-secondary btn-sm">🔍 Verify Medicine</a>
    </div>
  </div>

  <!-- Flash messages -->
  <% if (error && error.length) { %><div class="alert alert-danger py-2"><%= error %></div><% } %>
  <% if (success && success.length) { %><div class="alert alert-success py-2"><%= success %></div><% } %>

  <!-- Active Alerts Banner -->
  <% if (alerts && alerts.length) { %>
  <div class="alert alert-warning border-warning mb-4" role="alert">
    <div class="fw-semibold mb-1">⚠️ <%= alerts.length %> Active Alert(s)</div>
    <% alerts.slice(0,3).forEach(a => { %>
      <div class="small d-flex align-items-center gap-2 mt-1">
        <span class="badge bg-<%= a.severity==='CRITICAL'?'danger':a.severity==='HIGH'?'warning text-dark':'info' %>"><%= a.severity %></span>
        <span><%= a.message.substring(0,100) %><%= a.message.length>100?'...':'' %></span>
      </div>
    <% }) %>
    <% if(alerts.length>3){ %><a href="/admin/alerts" class="small text-warning d-block mt-1">View all <%= alerts.length %> alerts →</a><% } %>
  </div>
  <% } %>

  <!-- KPI Stats -->
  <div class="row g-4 mb-4">
    <div class="col-6 col-md-3">
      <div class="card text-white h-100 p-3" style="background:linear-gradient(135deg,#667eea,#764ba2)">
        <div class="kpi-number"><%= stats.totalMeds || 0 %></div>
        <div class="kpi-label">Medicine Batches</div>
      </div>
    </div>
    <div class="col-6 col-md-3">
      <div class="card text-white h-100 p-3" style="background:linear-gradient(135deg,#11998e,#38ef7d)">
        <div class="kpi-number"><%= stats.totalTests || 0 %></div>
        <div class="kpi-label">Tests Completed</div>
      </div>
    </div>
    <div class="col-6 col-md-3">
      <div class="card text-white h-100 p-3" style="background:linear-gradient(135deg,#f7971e,#ffd200)">
        <div class="kpi-number" style="color:#333"><%= stats.defective || 0 %></div>
        <div class="kpi-label" style="color:#444">Defective Batches</div>
      </div>
    </div>
    <div class="col-6 col-md-3">
      <div class="card text-white h-100 p-3" style="background:linear-gradient(135deg,#c0392b,#e74c3c)">
        <div class="kpi-number"><%= stats.totalAlerts || 0 %></div>
        <div class="kpi-label">Active Alerts</div>
      </div>
    </div>
  </div>

  <!-- Quick Actions -->
  <div class="row g-3 mb-4">
    <div class="col-12"><h6 class="text-muted fw-semibold text-uppercase" style="letter-spacing:1px; font-size:.75rem">Quick Actions</h6></div>
    <div class="col-6 col-md-3">
      <a href="/medicines/add" class="card text-decoration-none text-center p-3 h-100 action-card">
        <div style="font-size:2rem">🏭</div>
        <div class="fw-semibold mt-1 small">Register Batch</div>
      </a>
    </div>
    <div class="col-6 col-md-3">
      <a href="/testing" class="card text-decoration-none text-center p-3 h-100 action-card">
        <div style="font-size:2rem">🔬</div>
        <div class="fw-semibold mt-1 small">Test Quality</div>
      </a>
    </div>
    <div class="col-6 col-md-3">
      <a href="/supply" class="card text-decoration-none text-center p-3 h-100 action-card">
        <div style="font-size:2rem">🚚</div>
        <div class="fw-semibold mt-1 small">Transfer Medicine</div>
      </a>
    </div>
    <div class="col-6 col-md-3">
      <a href="/verify" class="card text-decoration-none text-center p-3 h-100 action-card">
        <div style="font-size:2rem">🔍</div>
        <div class="fw-semibold mt-1 small">Verify Authenticity</div>
      </a>
    </div>
  </div>

  <!-- Recent Batches Table -->
  <div class="card">
    <div class="card-header d-flex justify-content-between align-items-center">
      <span class="fw-semibold">📋 Recent Medicine Batches</span>
      <a href="/medicines" class="btn btn-sm btn-outline-primary">View All</a>
    </div>
    <div class="table-responsive">
      <table class="table table-hover mb-0">
        <thead class="table-dark">
          <tr>
            <th>Batch ID</th><th>Medicine</th><th>Manufacturer</th>
            <th>Expiry</th><th>Qty</th><th>Status</th><th>QR Code</th>
          </tr>
        </thead>
        <tbody>
        <% if(medicines && medicines.length) { %>
          <% medicines.forEach(m => { %>
          <tr>
            <td><a href="/verify/<%= m.batch_id %>" class="text-primary fw-mono"><%= m.batch_id %></a></td>
            <td><strong><%= m.medicine_name %></strong></td>
            <td><%= m.manufacturer_name %></td>
            <td class="<%= new Date(m.expiry_date) < new Date() ? 'text-danger fw-semibold' : '' %>">
              <%= new Date(m.expiry_date).toLocaleDateString('en-IN') %>
            </td>
            <td><%= m.quantity %></td>
            <td>
              <span class="badge bg-<%= m.status==='approved'?'success':m.status==='rejected'?'danger':'warning text-dark' %>">
                <%= m.status.toUpperCase() %>
              </span>
            </td>
            <td>
              <a href="/verify/<%= m.batch_id %>" target="_blank" title="Click to verify">
                <img
                  src="/medicines/qr/view/<%= m.batch_id %>"
                  width="46" height="46"
                  style="border-radius:6px;border:2px solid #dee2e6"
                  onerror="this.style.display='none'"
                  loading="lazy">
              </a>
            </td>
          </tr>
          <% }) %>
        <% } else { %>
          <tr><td colspan="7" class="text-center text-muted py-4">No medicine batches yet.</td></tr>
        <% } %>
        </tbody>
      </table>
    </div>
  </div>

</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
