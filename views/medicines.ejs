<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Medicines — PharmaTrace AI</title>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css">
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
<%- include('partials/navbar') %>
<div class="container-fluid px-4 py-4">

  <div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-2">
    <div>
      <h4 class="fw-bold mb-0">💊 Medicine Batches</h4>
      <p class="text-muted small mb-0">All registered medicine batches in the system</p>
    </div>
    <a href="/medicines/add" class="btn btn-primary">➕ Register New Batch</a>
  </div>

  <% if (error && error.length) { %><div class="alert alert-danger"><%= error %></div><% } %>
  <% if (success && success.length) { %><div class="alert alert-success"><%= success %></div><% } %>

  <!-- Filter bar -->
  <div class="card p-3 mb-3">
    <div class="row g-2">
      <div class="col-md-4">
        <input type="text" id="searchInput" class="form-control form-control-sm" placeholder="🔍 Search batch ID or name...">
      </div>
      <div class="col-md-3">
        <select id="statusFilter" class="form-select form-select-sm">
          <option value="">All Statuses</option>
          <option value="pending">Pending</option>
          <option value="approved">Approved</option>
          <option value="rejected">Rejected</option>
        </select>
      </div>
    </div>
  </div>

  <div class="card">
    <div class="table-responsive">
      <table class="table table-hover mb-0" id="medTable">
        <thead class="table-dark">
          <tr>
            <th>#</th>
            <th>Batch ID</th>
            <th>Medicine Name</th>
            <th>Manufacturer</th>
            <th>Mfg Date</th>
            <th>Expiry Date</th>
            <th>Qty</th>
            <th>Package</th>
            <th>Status</th>
            <th>QR Code</th>
            <th>Actions</th>
          </tr>
        </thead>
        <tbody>
        <% if(medicines && medicines.length) { %>
          <% medicines.forEach((m, idx) => { %>
          <tr data-status="<%= m.status %>">
            <td class="text-muted small"><%= idx+1 %></td>
            <td><a href="/verify/<%= m.batch_id %>" class="text-primary fw-semibold text-decoration-none"><code><%= m.batch_id %></code></a></td>
            <td><strong><%= m.medicine_name %></strong>
              <% if(m.dosage_form){ %><br><small class="text-muted"><%= m.dosage_form %></small><% } %>
            </td>
            <td><%= m.manufacturer_name %></td>
            <td><%= new Date(m.manufacturing_date).toLocaleDateString('en-IN') %></td>
            <td class="<%= new Date(m.expiry_date) < new Date() ? 'text-danger fw-semibold' : 'text-success' %>">
              <%= new Date(m.expiry_date).toLocaleDateString('en-IN') %>
              <% if(new Date(m.expiry_date) < new Date()){ %><br><span class="badge bg-danger" style="font-size:.65rem">EXPIRED</span><% } %>
            </td>
            <td><%= m.quantity.toLocaleString() %></td>
            <td><small class="text-muted"><%= m.package_type || '—' %></small></td>
            <td>
              <span class="badge bg-<%= m.status==='approved'?'success':m.status==='rejected'?'danger':'warning text-dark' %>">
                <%= m.status.toUpperCase() %>
              </span>
            </td>
            <td>
              <a href="/verify/<%= m.batch_id %>" target="_blank" title="Scan QR to verify">
                <img
                  src="/medicines/qr/view/<%= m.batch_id %>"
                  width="50" height="50"
                  style="border-radius:8px;border:2px solid #dee2e6;cursor:pointer"
                  onerror="this.style.display='none'"
                  loading="lazy">
              </a>
              <div class="mt-1">
                <a href="/medicines/qr/view/<%= m.batch_id %>" download="QR-<%= m.batch_id %>.png" class="btn btn-outline-secondary btn-sm" style="font-size:.65rem;padding:2px 6px">📥</a>
              </div>
            </td>
            <td class="d-flex gap-1 flex-wrap">
              <a href="/verify/<%= m.batch_id %>" class="btn btn-outline-primary btn-sm">🔍 Verify</a>
              <a href="/medicines/qr/page/<%= m.batch_id %>" class="btn btn-outline-secondary btn-sm" target="_blank">📱 QR</a>
            </td>
          </tr>
          <% }) %>
        <% } else { %>
          <tr><td colspan="11" class="text-center text-muted py-5">
            No medicines registered yet. <a href="/medicines/add">Register the first batch →</a>
          </td></tr>
        <% } %>
        </tbody>
      </table>
    </div>
  </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
<script>
  document.getElementById('searchInput').addEventListener('input', filterTable);
  document.getElementById('statusFilter').addEventListener('change', filterTable);
  function filterTable() {
    const q = document.getElementById('searchInput').value.toLowerCase();
    const s = document.getElementById('statusFilter').value;
    document.querySelectorAll('#medTable tbody tr').forEach(row => {
      const text   = row.textContent.toLowerCase();
      const status = row.dataset.status;
      const matchQ = !q || text.includes(q);
      const matchS = !s || status === s;
      row.style.display = (matchQ && matchS) ? '' : 'none';
    });
  }
</script>
</body>
</html>
