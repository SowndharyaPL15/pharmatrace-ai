<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Analytics — PharmaTrace AI</title>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css">
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
<%- include('partials/navbar') %>
<div class="container-fluid px-4 py-4">

  <div class="d-flex align-items-center gap-3 mb-4">
    <div style="font-size:2.5rem">📊</div>
    <div>
      <h4 class="fw-bold mb-0">Admin Analytics Dashboard</h4>
      <p class="text-muted small mb-0">System-wide statistics, charts and AI anomaly detection results</p>
    </div>
  </div>

  <!-- KPI Cards -->
  <div class="row g-4 mb-4">
    <div class="col-6 col-md-3">
      <div class="card text-white p-4" style="background:linear-gradient(135deg,#667eea,#764ba2)">
        <div class="kpi-number"><%= stats.totalMeds %></div>
        <div class="kpi-label">Medicine Batches</div>
      </div>
    </div>
    <div class="col-6 col-md-3">
      <div class="card text-white p-4" style="background:linear-gradient(135deg,#11998e,#38ef7d)">
        <div class="kpi-number"><%= stats.totalTests %></div>
        <div class="kpi-label">Tests Completed</div>
      </div>
    </div>
    <div class="col-6 col-md-3">
      <div class="card text-white p-4" style="background:linear-gradient(135deg,#f7971e,#ffd200)">
        <div class="kpi-number" style="color:#333"><%= stats.defective %></div>
        <div class="kpi-label" style="color:#333">Defective Batches</div>
      </div>
    </div>
    <div class="col-6 col-md-3">
      <div class="card text-white p-4" style="background:linear-gradient(135deg,#c0392b,#e74c3c)">
        <div class="kpi-number"><%= stats.totalAlerts %></div>
        <div class="kpi-label">Total Alerts</div>
      </div>
    </div>
  </div>

  <!-- Charts -->
  <div class="row g-4 mb-4">
    <div class="col-md-4">
      <div class="card p-3">
        <canvas id="statusChart" height="280"></canvas>
      </div>
    </div>
    <div class="col-md-4">
      <div class="card p-3">
        <canvas id="alertChart" height="280"></canvas>
      </div>
    </div>
    <div class="col-md-4">
      <div class="card p-3">
        <canvas id="monthlyChart" height="280"></canvas>
      </div>
    </div>
  </div>

  <!-- Users by Role -->
  <div class="row g-4 mb-4">
    <div class="col-md-4">
      <div class="card p-3">
        <canvas id="userChart" height="260"></canvas>
      </div>
    </div>
    <div class="col-md-8">
      <!-- Recent Alerts Table -->
      <div class="card">
        <div class="card-header fw-semibold d-flex justify-content-between">
          <span>🚨 Recent Alerts</span>
          <a href="/admin/alerts" class="btn btn-sm btn-outline-danger">View All</a>
        </div>
        <div class="table-responsive">
          <table class="table table-sm mb-0">
            <thead class="table-dark"><tr><th>Batch</th><th>Type</th><th>Severity</th><th>Message</th><th>Date</th></tr></thead>
            <tbody>
            <% recentAlerts.forEach(a => { %>
              <tr>
                <td><code class="small"><%= a.batch_id || '—' %></code></td>
                <td class="small"><%= a.alert_type %></td>
                <td><span class="badge bg-<%= a.severity==='CRITICAL'?'danger':a.severity==='HIGH'?'warning text-dark':'info' %>" style="font-size:.65rem"><%= a.severity %></span></td>
                <td class="small"><%= a.message.substring(0,60) %>...</td>
                <td class="small text-muted"><%= new Date(a.created_at).toLocaleDateString('en-IN') %></td>
              </tr>
            <% }) %>
            </tbody>
          </table>
        </div>
      </div>
    </div>
  </div>

  <!-- WHO Mock API -->
  <div class="card p-4 mb-4">
    <h5 class="fw-semibold mb-1">🌐 WHO Medicine Database Verification</h5>
    <p class="text-muted small mb-3">Simulate verification against the WHO pharmaceutical database</p>
    <div class="d-flex gap-2 flex-wrap">
      <input type="text" id="whoInput" class="form-control" style="max-width:300px"
             placeholder="Enter Batch ID to verify">
      <button class="btn btn-info text-white fw-semibold" onclick="whoVerify()">Verify with WHO</button>
    </div>
    <div id="whoResult" class="mt-3"></div>
  </div>

  <!-- AI Service Results -->
  <div class="card p-4">
    <h5 class="fw-semibold mb-1">🤖 AI Anomaly Detection Results</h5>
    <p class="text-muted small mb-3">Isolation Forest model — results from quality test submissions</p>
    <div id="aiResults">
      <div class="text-muted small">Loading AI results...</div>
    </div>
  </div>

</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
<script src="/js/charts.js"></script>
<script>
  const statusData  = <%- JSON.stringify(byStatus) %>;
  const alertData   = <%- JSON.stringify(bySeverity) %>;
  const monthlyData = <%- JSON.stringify(monthlyTests) %>;
  const userData    = <%- JSON.stringify(allUsers) %>;

  createDoughnutChart(
    'statusChart',
    statusData.map(d => d.status.toUpperCase()),
    statusData.map(d => parseInt(d.count)),
    'Medicine Status Distribution'
  );

  createBarChart(
    'alertChart',
    alertData.map(d => d.severity),
    alertData.map(d => parseInt(d.count)),
    'Alerts by Severity',
    ['#6c757d','#17a2b8','#ffc107','#dc3545']
  );

  createLineChart(
    'monthlyChart',
    monthlyData.map(d => d.month),
    monthlyData.map(d => parseInt(d.count)),
    'Monthly Tests Trend'
  );

  createDoughnutChart(
    'userChart',
    userData.map(d => d.role.toUpperCase()),
    userData.map(d => parseInt(d.count)),
    'Users by Role'
  );

  // WHO verify
  async function whoVerify() {
    const batchId = document.getElementById('whoInput').value.trim();
    if (!batchId) return;
    const res  = await fetch(`/admin/api/who-verify/${encodeURIComponent(batchId)}`);
    const data = await res.json();
    document.getElementById('whoResult').innerHTML = data.verified
      ? `<div class="alert alert-success">✅ <strong>${batchId}</strong> verified — ${data.medicine} by ${data.manufacturer} | Status: ${data.status} | Expiry: ${new Date(data.expiry).toLocaleDateString()}</div>`
      : `<div class="alert alert-danger">❌ ${data.message}</div>`;
  }

  // Load AI results
  fetch('http://localhost:5001/results')
    .then(r => r.json())
    .then(data => {
      const el = document.getElementById('aiResults');
      if (!data.length) {
        el.innerHTML = '<div class="alert alert-secondary small">No AI analysis results yet. Submit a quality test to see results.</div>';
        return;
      }
      let html = '<div class="table-responsive"><table class="table table-bordered table-sm"><thead class="table-dark"><tr><th>Batch ID</th><th>Anomaly</th><th>Risk Level</th><th>Score</th><th>Recommendation</th></tr></thead><tbody>';
      data.forEach(r => {
        html += `<tr>
          <td><code>${r.batch_id}</code></td>
          <td>${r.is_anomaly ? '<span class="badge bg-danger">YES</span>' : '<span class="badge bg-success">NO</span>'}</td>
          <td><span class="badge bg-${r.risk_level==='HIGH'?'danger':r.risk_level==='MEDIUM'?'warning text-dark':'success'}">${r.risk_level}</span></td>
          <td>${r.anomaly_score.toFixed(4)}</td>
          <td class="small">${r.recommendation}</td>
        </tr>`;
      });
      el.innerHTML = html + '</tbody></table></div>';
    })
    .catch(() => {
      document.getElementById('aiResults').innerHTML =
        '<div class="alert alert-warning small">⚠️ AI service not running. Start it with: <code>cd ai_service && python fraud_detection.py</code></div>';
    });
</script>
</body>
</html>
