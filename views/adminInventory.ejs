<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"><meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Inventory — PharmaTrace AI</title>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css">
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
<%- include('partials/navbar') %>
<div class="container-fluid px-4 py-4">
  <h4 class="fw-bold mb-1">📦 Inventory Overview</h4>
  <p class="text-muted small mb-4">Current medicine stock across all entities in the supply chain</p>

  <div class="card">
    <div class="table-responsive">
      <table class="table table-hover mb-0">
        <thead class="table-dark">
          <tr><th>#</th><th>Batch ID</th><th>Medicine</th><th>Owner</th><th>Role</th><th>Organization</th><th>Quantity</th><th>Expiry</th><th>Status</th><th>Updated</th></tr>
        </thead>
        <tbody>
        <% inventory.forEach((item, i) => { %>
          <tr class="<%= item.quantity === 0 ? 'text-muted' : '' %>">
            <td class="small"><%= i+1 %></td>
            <td><a href="/verify/<%= item.batch_id %>" class="text-primary"><code><%= item.batch_id %></code></a></td>
            <td class="fw-semibold small"><%= item.medicine_name %></td>
            <td class="small"><%= item.owner_name %></td>
            <td><span class="badge bg-secondary" style="font-size:.65rem"><%= item.owner_role %></span></td>
            <td class="small text-muted"><%= item.organization || '—' %></td>
            <td>
              <span class="fw-bold <%= item.quantity === 0 ? 'text-danger' : 'text-success' %>">
                <%= item.quantity.toLocaleString() %>
              </span>
            </td>
            <td class="small <%= new Date(item.expiry_date) < new Date() ? 'text-danger fw-bold' : '' %>">
              <%= new Date(item.expiry_date).toLocaleDateString('en-IN') %>
            </td>
            <td>
              <span class="badge bg-<%= item.med_status==='approved'?'success':item.med_status==='rejected'?'danger':'warning text-dark' %>">
                <%= item.med_status %>
              </span>
            </td>
            <td class="small text-muted"><%= new Date(item.updated_at).toLocaleDateString('en-IN') %></td>
          </tr>
        <% }) %>
        </tbody>
      </table>
    </div>
  </div>
</div>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
