<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>QR Code — <%= batchId %> — PharmaTrace AI</title>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css">
  <link rel="stylesheet" href="/css/style.css">
  <style>
    body { background:#f0f2f5; }
    .qr-card {
      background:white; border-radius:20px;
      box-shadow:0 8px 40px rgba(0,0,0,.12);
      padding:40px; text-align:center;
      max-width:480px; margin:0 auto;
    }
    .qr-img-wrapper {
      background:white; border:4px solid #0d6efd;
      border-radius:16px; padding:16px;
      display:inline-block; margin-bottom:20px;
    }
    @media print {
      .no-print { display:none !important; }
      body { background:white; }
      .qr-card { box-shadow:none; border:1px solid #ddd; }
    }
  </style>
</head>
<body>
<div class="no-print"><%- include('partials/navbar') %></div>

<div class="container py-5">
  <div class="qr-card">

    <div class="mb-3">
      <span style="font-size:2.5rem">💊</span>
      <h4 class="fw-bold mt-2 mb-0">PharmaTrace AI</h4>
      <p class="text-muted small">Official Medicine Authentication QR Code</p>
    </div>

    <!-- Live QR image served from endpoint -->
    <div class="qr-img-wrapper">
      <img id="qrImage"
           src="/medicines/qr/view/<%= batchId %>"
           width="280" height="280"
           alt="QR Code for <%= batchId %>"
           style="display:block">
    </div>

    <div class="mt-2">
      <div class="badge bg-primary mb-2" style="font-size:.9rem; padding:8px 16px">
        <code style="color:white; font-size:.95rem"><%= batchId %></code>
      </div>
      <% if(medicine) { %>
        <h5 class="fw-bold mb-1"><%= medicine.medicine_name %></h5>
        <p class="text-muted small mb-0">By <%= medicine.manufacturer_name %></p>
        <p class="small mt-1">
          <span class="badge bg-<%= medicine.status==='approved'?'success':medicine.status==='rejected'?'danger':'warning text-dark' %>">
            <%= medicine.status.toUpperCase() %>
          </span>
          &nbsp; Exp: <strong><%= new Date(medicine.expiry_date).toLocaleDateString('en-IN') %></strong>
        </p>
      <% } %>
    </div>

    <div class="mt-3 p-3 rounded" style="background:#f8f9fa;">
      <p class="text-muted small mb-1 fw-semibold">SCAN TO VERIFY AT:</p>
      <p class="small mb-0" style="word-break:break-all">
        <a href="<%= verifyUrl %>" target="_blank" class="text-primary"><%= verifyUrl %></a>
      </p>
    </div>

    <div class="d-flex gap-2 justify-content-center mt-4 flex-wrap no-print">
      <a id="downloadBtn"
         href="/medicines/qr/view/<%= batchId %>"
         download="QR-<%= batchId %>.png"
         class="btn btn-primary">📥 Download PNG</a>
      <button class="btn btn-outline-secondary" onclick="window.print()">🖨️ Print</button>
      <a href="/verify/<%= batchId %>" class="btn btn-outline-success">🔍 Verify Now</a>
    </div>

    <p class="mt-4 text-muted small no-print">
      📱 Open <strong><%= verifyUrl %></strong> in any browser to verify,<br>
      or use the <strong>📷 Scan QR</strong> button on the Verify page.
    </p>
  </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
<script>
  // Upgrade to base64 for higher quality download
  fetch('/qr/api/<%= batchId %>')
    .then(r => r.json())
    .then(data => {
      if (data.success) {
        const img = document.getElementById('qrImage');
        const btn = document.getElementById('downloadBtn');
        if (img) img.src = data.dataUrl;
        if (btn) { btn.href = data.dataUrl; btn.download = 'QR-<%= batchId %>.png'; }
      }
    }).catch(() => {});
</script>
</body>
</html>
