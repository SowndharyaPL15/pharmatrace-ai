<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Quality Testing — PharmaTrace AI</title>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css">
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
<%- include('partials/navbar') %>
<div class="container-fluid px-4 py-4">

  <div class="d-flex align-items-center gap-3 mb-4">
    <div style="font-size:2.5rem">🔬</div>
    <div>
      <h4 class="fw-bold mb-0">Medicine Quality Testing</h4>
      <p class="text-muted small mb-0">Submit lab test results. Purity ≥80% + Sterility Pass = SAFE. Otherwise DEFECTIVE.</p>
    </div>
  </div>

  <% if (error && error.length) { %><div class="alert alert-danger"><%= error %></div><% } %>
  <% if (success && success.length) { %><div class="alert alert-success"><%= success %></div><% } %>

  <div class="row g-4">

    <!-- Test Form -->
    <div class="col-lg-5">
      <div class="card">
        <div class="card-header fw-semibold">📝 Submit Test Results</div>
        <div class="card-body">
          <form method="POST" action="/testing/submit">
            <div class="mb-3">
              <label class="form-label">Select Batch <span class="text-danger">*</span></label>
              <select name="batch_id" class="form-select" required>
                <option value="">-- Select pending batch --</option>
                <% medicines.forEach(m => { %>
                  <option value="<%= m.batch_id %>"><%= m.batch_id %> — <%= m.medicine_name %></option>
                <% }) %>
              </select>
              <% if(!medicines.length) { %>
                <div class="form-text text-warning">No pending batches. All batches have been tested.</div>
              <% } %>
            </div>

            <div class="mb-3">
              <label class="form-label">Lab Name</label>
              <input type="text" name="lab_name" class="form-control" placeholder="e.g. National Quality Lab, Mumbai">
            </div>

            <div class="row g-2 mb-3">
              <div class="col-6">
                <label class="form-label">Purity % <span class="text-danger">*</span></label>
                <input type="number" name="purity_percentage" id="purityInput"
                       step="0.01" min="0" max="100" class="form-control" placeholder="95.50" required>
                <div class="form-text">Min 80% required</div>
              </div>
              <div class="col-6">
                <label class="form-label">pH Level <span class="text-danger">*</span></label>
                <input type="number" name="ph_level" step="0.01" min="0" max="14" class="form-control" placeholder="7.0" required>
              </div>
            </div>

            <div class="row g-2 mb-3">
              <div class="col-6">
                <label class="form-label">Dissolution Rate %</label>
                <input type="number" name="dissolution_rate" step="0.01" min="0" max="100" class="form-control" placeholder="85.0">
              </div>
              <div class="col-6">
                <label class="form-label">Moisture Content %</label>
                <input type="number" name="moisture_content" step="0.01" min="0" max="100" class="form-control" placeholder="2.5">
              </div>
            </div>

            <div class="mb-3">
              <label class="form-label">Sterility Status <span class="text-danger">*</span></label>
              <div class="d-flex gap-3">
                <div class="form-check">
                  <input class="form-check-input" type="radio" name="sterility_status" value="true" id="sterilePass" required>
                  <label class="form-check-label text-success fw-semibold" for="sterilePass">✅ Pass</label>
                </div>
                <div class="form-check">
                  <input class="form-check-input" type="radio" name="sterility_status" value="false" id="sterileFail">
                  <label class="form-check-label text-danger fw-semibold" for="sterileFail">❌ Fail</label>
                </div>
              </div>
            </div>

            <div class="mb-3">
              <label class="form-label">Contamination Detected?</label>
              <div class="d-flex gap-3">
                <div class="form-check">
                  <input class="form-check-input" type="radio" name="contamination_flag" value="false" id="contNo" checked>
                  <label class="form-check-label text-success" for="contNo">✅ No</label>
                </div>
                <div class="form-check">
                  <input class="form-check-input" type="radio" name="contamination_flag" value="true" id="contYes">
                  <label class="form-check-label text-danger fw-semibold" for="contYes">⚠️ Yes</label>
                </div>
              </div>
            </div>

            <div class="mb-3">
              <label class="form-label">Inspector Notes</label>
              <textarea name="notes" class="form-control" rows="3" placeholder="Any observations or remarks..."></textarea>
            </div>

            <!-- Live result preview -->
            <div id="resultPreview" class="alert alert-secondary small mb-3" style="display:none"></div>

            <button type="submit" class="btn btn-success w-100 py-2 fw-semibold">Submit Test Results</button>
          </form>
        </div>
      </div>

      <!-- Quality algorithm info -->
      <div class="card mt-3">
        <div class="card-header fw-semibold small">ℹ️ Quality Algorithm</div>
        <div class="card-body small">
          <div class="d-flex align-items-center gap-2 mb-2">
            <span class="badge bg-success">SAFE</span>
            <span>Purity ≥80% <strong>AND</strong> Sterility PASS <strong>AND</strong> No contamination</span>
          </div>
          <div class="d-flex align-items-center gap-2">
            <span class="badge bg-danger">DEFECTIVE</span>
            <span>Purity &lt;80% <strong>OR</strong> Sterility FAIL <strong>OR</strong> Contamination detected</span>
          </div>
        </div>
      </div>
    </div>

    <!-- Recent Tests -->
    <div class="col-lg-7">
      <div class="card">
        <div class="card-header fw-semibold">📊 Recent Test Results</div>
        <div class="table-responsive">
          <table class="table table-hover table-sm mb-0">
            <thead class="table-dark">
              <tr><th>Batch ID</th><th>Medicine</th><th>Inspector</th><th>Purity</th><th>pH</th><th>Sterile</th><th>Cont.</th><th>AI Risk</th><th>Result</th><th>Date</th></tr>
            </thead>
            <tbody>
            <% if(tests && tests.length) { %>
              <% tests.forEach(t => { %>
              <tr>
                <td><code class="small"><%= t.batch_id %></code></td>
                <td class="small"><%= t.medicine_name %></td>
                <td class="small"><%= t.inspector_name %></td>
                <td class="<%= t.purity_percentage < 80 ? 'text-danger fw-bold' : 'text-success' %> small"><%= t.purity_percentage %>%</td>
                <td class="small"><%= t.ph_level %></td>
                <td><%= t.sterility_status ? '✅' : '❌' %></td>
                <td><%= t.contamination_flag ? '⚠️' : '✅' %></td>
                <td>
                  <% if(t.ai_risk_level) { %>
                    <span class="badge bg-<%= t.ai_risk_level==='HIGH'?'danger':t.ai_risk_level==='MEDIUM'?'warning text-dark':'success' %>" style="font-size:.65rem"><%= t.ai_risk_level %></span>
                  <% } else { %><span class="text-muted small">—</span><% } %>
                </td>
                <td><span class="badge bg-<%= t.test_result==='SAFE'?'success':'danger' %>"><%= t.test_result %></span></td>
                <td class="small text-muted"><%= new Date(t.tested_at).toLocaleDateString('en-IN') %></td>
              </tr>
              <% }) %>
            <% } else { %>
              <tr><td colspan="10" class="text-center text-muted py-4">No tests recorded yet.</td></tr>
            <% } %>
            </tbody>
          </table>
        </div>
      </div>
    </div>
  </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
<script>
  // Live result preview
  function updatePreview() {
    const purity  = parseFloat(document.getElementById('purityInput').value);
    const sterile = document.querySelector('input[name="sterility_status"]:checked')?.value;
    const contam  = document.querySelector('input[name="contamination_flag"]:checked')?.value;
    const preview = document.getElementById('resultPreview');
    if (isNaN(purity)) { preview.style.display='none'; return; }
    const isSafe = purity >= 80 && sterile === 'true' && contam === 'false';
    preview.style.display = 'block';
    preview.className = `alert small mb-3 ${isSafe ? 'alert-success' : 'alert-danger'}`;
    preview.innerHTML = `<strong>Predicted Result:</strong> ${isSafe ? '✅ SAFE — Batch will be APPROVED' : '❌ DEFECTIVE — Batch will be REJECTED'}`;
  }
  document.getElementById('purityInput').addEventListener('input', updatePreview);
  document.querySelectorAll('input[type="radio"]').forEach(r => r.addEventListener('change', updatePreview));
</script>
</body>
</html>
